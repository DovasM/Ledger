# Gradle
.gradle/
build/
**/build/
!gradle/wrapper/gradle-wrapper.jar

# Local configuration (contains SDK path — never commit)
local.properties

# Android Studio / IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr
.DS_Store

# Rust build output — never commit the entire target tree
core/target/

# NDK — ignore generated .so files everywhere EXCEPT the jniLibs that the app ships
*.so
!app/src/main/jniLibs/**/*.so

# Android Gradle Plugin CMake intermediate build directory
app/.cxx/

# llama.cpp Rust build output (inside core/target, already covered, but explicit)
third_party/llama.cpp/build*

# Vulkan/SPIR-V header repos cloned for Vulkan build — large, not modified
third_party/Vulkan-Headers/
third_party/SPIRV-Headers/

# Short-path Vulkan build output dir (CARGO_TARGET_DIR=C:\lt, outside project)
# Nothing to ignore here — it lives at C:\lt, not inside the repo.

# SPIRV-Headers cmake install tree (generated, not source)
third_party/SPIRV-Headers-install/

# APKs / AABs / release artifacts
*.apk
*.aab
*.ap_

# Keystore files (NEVER commit these)
*.jks
*.keystore

# Proguard / R8 mapping files
/app/mapping.txt

# JVM crash dumps
*.hprof

# Navigation SafeArgs generated sources
app/src/main/java/**/directions/
app/src/main/java/**/directions

# Kotlin coroutines debug
kotlin-coroutines-debug*.jar

# Captured heap dumps
captures/

# Test results
app/src/test/
app/src/androidTest/

# OS files
Thumbs.db
ehthumbs.db
Desktop.ini

# Claude AI generated files
.claude
.claude/*

# Test folder
test/
